class Child {
    // インスタンス化された直後に呼ばれる
    public fn initialize() {
        let myName = this.getName();
        let parentName = this.getParent() as string;
        
        // 文字列補間を使用してログを出力
        global.log("  [Child] 👶 子インスタンス '${myName}' が誕生しました！ (親: ${parentName})");
    }

    // 親から呼び出されるメソッド
    public fn doWork(string taskName) {
        let myName = this.getName();
        global.log("  [Child] 🛠️ '${myName}' がタスク「${taskName}」を実行中...");
    }
}